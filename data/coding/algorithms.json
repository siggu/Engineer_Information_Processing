      "id": "algo_01",
      "title": "정렬 알고리즘",
      "algorithms": [
        {
          "name": "버블 정렬 (Bubble Sort)",
          "time_complexity": "O(n²)",
          "description": "인접한 두 원소를 비교하여 교환",
          "c_code": "for(int i=0; i<n-1; i++)\n  for(int j=0; j<n-1-i; j++)\n    if(a[j] > a[j+1]) swap(a[j], a[j+1]);"
        },
        {
          "name": "선택 정렬 (Selection Sort)",
          "time_complexity": "O(n²)",
          "description": "최솟값을 찾아 앞으로 이동",
          "c_code": "for(int i=0; i<n-1; i++) {\n  int min = i;\n  for(int j=i+1; j<n; j++)\n    if(a[j] < a[min]) min = j;\n  swap(a[i], a[min]);\n}"
        },
        {
          "name": "삽입 정렬 (Insertion Sort)",
          "time_complexity": "O(n²)",
          "description": "현재 원소를 적절한 위치에 삽입",
          "note": "거의 정렬된 데이터에 효율적"
        },
        {
          "name": "퀵 정렬 (Quick Sort)",
          "time_complexity": "평균 O(n log n), 최악 O(n²)",
          "description": "피벗을 기준으로 분할 정복"
        },
        {
          "name": "병합 정렬 (Merge Sort)",
          "time_complexity": "O(n log n)",
          "description": "분할 정복, 안정 정렬"
        }
      ]
    },
